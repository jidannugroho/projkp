# Nginx Configuration untuk Asetcore1
# Copy ke: /etc/nginx/sites-available/asetcore1
# Enable dengan: sudo ln -s /etc/nginx/sites-available/asetcore1 /etc/nginx/sites-enabled/
# Test dengan: sudo nginx -t
# Reload dengan: sudo systemctl reload nginx



# Upstream configuration
upstream asetcore1_backend {
    server localhost:8080 fail_timeout=30s max_fails=3;
    keepalive 32;
}

# Redirect HTTP to HTTPS (uncomment untuk production dengan SSL)
# server {
#     listen 80;
